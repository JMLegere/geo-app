# ============================================================================
# EarthNova — Flutter / Dart / Supabase
# ============================================================================

# ---------------------------------------------------------------------------
# Dart & Flutter
# ---------------------------------------------------------------------------
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
build/
.pub-cache/
.pub/

# Dart compiled JS (dart2js)
*.dart.js
*.dart.js.deps
*.dart.js.map
*.dart.precompiled.js

# Flutter generated plugin registrants (per-platform gitignores handle these
# too, but belt-and-suspenders for monorepo root)
**/generated_plugin_registrant.cc
**/generated_plugin_registrant.h
**/generated_plugins.cmake
**/GeneratedPluginRegistrant.swift
**/GeneratedPluginRegistrant.java

# Coverage
coverage/

# ---------------------------------------------------------------------------
# IDE & Editors
# ---------------------------------------------------------------------------
# IntelliJ / Android Studio
.idea/
*.iml

# VS Code
.vscode/

# Vim / Emacs / others
*.swp
*.swo
*~
\#*\#
.#*

# ---------------------------------------------------------------------------
# OS
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
._*

# ---------------------------------------------------------------------------
# Environment & Secrets
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example

# Keystore / signing (Android sub-gitignore also covers these)
*.keystore
*.jks
key.properties

# ---------------------------------------------------------------------------
# SQLite & Databases
# ---------------------------------------------------------------------------
# Runtime databases (local dev)
*.db
!assets/species.db

# SQLite WAL/SHM (ephemeral, never commit)
*.db-shm
*.db-wal
*.db-journal

# ---------------------------------------------------------------------------
# Supabase
# ---------------------------------------------------------------------------
supabase/.branches/
supabase/.temp/

# ---------------------------------------------------------------------------
# Terraform / Infrastructure
# ---------------------------------------------------------------------------
.terraform/
*.tfstate
*.tfstate.backup
*.tfvars
!*.tfvars.example
.terraform.lock.hcl

# ---------------------------------------------------------------------------
# Node.js (E2E / scripting tooling)
# ---------------------------------------------------------------------------
node_modules/
package-lock.json
yarn.lock
pnpm-lock.yaml

# ---------------------------------------------------------------------------
# Python (scripts/)
# ---------------------------------------------------------------------------
__pycache__/
*.pyc
.venv/
venv/

# ---------------------------------------------------------------------------
# Agent / AI Working Memory
# ---------------------------------------------------------------------------
.claude/
.sisyphus/
.agents/

# ---------------------------------------------------------------------------
# Ephemeral Artifacts
# ---------------------------------------------------------------------------
# Screenshots and logs from agent runs
/*.png
/*.jpeg
/*.log
e2e-console-log.txt
scripts/.cache/

# Crash logs
crash_log.*
*.stacktrace

# ---------------------------------------------------------------------------
# Native Build Artifacts (not covered by platform sub-gitignores)
# ---------------------------------------------------------------------------
*.apk
*.aab
*.ipa
*.app
*.dSYM/
*.dSYM.zip

# ---------------------------------------------------------------------------
# E2E (Playwright)
# ---------------------------------------------------------------------------
e2e/node_modules/
e2e/dist/
e2e/test-results/
e2e/playwright-report/
e2e/.cache/
.playwright-mcp/
