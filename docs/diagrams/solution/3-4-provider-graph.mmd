    items --> identification
    speciesSync --> identification
    writeQueue --> identification

    items --> sanctuary
    writeQueue --> sanctuary

    items --> recap
    auth --> recap

    items --> skillProgress
    auth --> skillProgress

    speciesSync --> encounter
    items --> encounter

    locationProv --> cellVisit
    supabase --> cellVisit

