%% Status: NEEDS HUMAN REVIEW
%% Problem: a2-reveal-fog.mmd, a3-encounter-collect.mmd
%% Related: a-4-exploration-sequence.mmd, a-3-exploration-data.mmd, 7-4-encounter-selection.mmd
sequenceDiagram
    participant GPS
    participant CellService
    participant EncounterService
    participant SpeciesDB
    participant ItemService
    participant Supabase
    participant PackScreen
    participant ObservabilityService

    GPS->>CellService: location coordinates (lat, lng)
    CellService->>CellService: Determine current Voronoi cell from coordinates
    CellService->>CellService: Resolve cell → district → city → state → country
    CellService->>Supabase: Check if cell is new visit
    alt New cell visit
        CellService->>Supabase: INSERT v3_cell_visits
        CellService->>CellService: Recompute hierarchy stats (district → city → state → country %)
    end

    CellService->>EncounterService: cellId, dailySeed
    EncounterService->>EncounterService: SHA-256(dailySeed + "_" + cellId) for 3 encounter slots

    loop For each of 3 encounter slots
        EncounterService->>SpeciesDB: Map hash segment to species catalog index (rarity-weighted)
        SpeciesDB-->>EncounterService: Species definition
        EncounterService->>ItemService: Create unidentified item for species
        ItemService->>Supabase: INSERT v3_items (status=active, identified=false)
        Supabase-->>ItemService: Item created
        ItemService->>PackScreen: New item via provider
        ItemService->>ObservabilityService: Log discovery.item_acquired
    end

    EncounterService->>ObservabilityService: Log discovery.encounter
    PackScreen->>PackScreen: Show "You found something!" modal
