flowchart TD
    subgraph JTBD["JTBD Canvas -- L3-S.4: Animate the World"]
        JP["<b>Job Performer</b><br/>Animation System:<br/>client-side rendering framework"]
        ASP["<b>Aspirations</b><br/>95% warm: gentle springs,<br/>breathing, soft shadows<br/>5% electric: particles,<br/>haptic, glow"]
        FJ["<b>Focus Job</b><br/>Animate the world:<br/>spring physics, particles"]
        RJ["<b>Related Jobs</b><br/>S.3: Persist progress<br/>B.2: Hold to identify<br/>A.3: Encounter and collect"]
