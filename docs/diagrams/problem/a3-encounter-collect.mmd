flowchart TD
    subgraph JTBD["JTBD Canvas -- L3-A.3: Encounter and Collect Species"]
        JP["<b>Job Performer</b><br/>Explorer who just<br/>entered a new cell"]
        ASP["<b>Aspirations</b><br/>Every cell holds surprises<br/>The catalog is vast: 32,752 species<br/>Each discovery is real"]
