flowchart TD
    subgraph JTBD["JTBD Canvas -- L3-A.3: Encounter and Collect Species"]
        JP["<b>Job Performer</b><br/>Explorer who just<br/>entered a new cell"]
        ASP["<b>Aspirations</b><br/>Every cell holds surprises<br/>The catalog is vast: 32,752 species<br/>Each discovery is real"]
        FJ["<b>Focus Job</b><br/>Encounter and collect species"]
        RJ["<b>Related Jobs</b><br/>A.1: Navigate map<br/>A.2: Reveal fog<br/>B: Identify specimens"]
        PLAN["<b>PLAN</b><br/>Enter cell"]
        PREPARE["<b>PREPARE</b><br/>System computes encounters<br/>from daily seed + cell ID"]
        EXECUTE["<b>EXECUTE</b><br/>3 encounter slots resolved,<br/>species selected from<br/>32,752 IUCN catalog"]
        MONITOR["<b>MONITOR</b><br/>Discovery modal:<br/>You found something!<br/>Items appear in pack"]
        MODIFY["<b>MODIFY</b><br/>Revisit cells on different<br/>days for different encounters"]
        CONCLUDE["<b>CONCLUDE</b><br/>1-3 unidentified items<br/>now in pack"]
        SC["<b>Success Criteria</b><br/>Deterministic: same seed+cell = same species<br/>Rarity-weighted selection<br/>Items created in pack"]
        EM["<b>Emotions</b><br/>Surprise --> Excitement --> Collecting satisfaction"]
        CIRC["<b>Circumstances</b><br/>First visit to cell<br/>on a given daily seed"]

        JP --> FJ
        ASP --> FJ
        FJ --> PLAN
        PLAN --> PREPARE --> EXECUTE --> MONITOR --> MODIFY --> CONCLUDE
        FJ --> RJ
        FJ --> SC
        FJ --> EM
        FJ --> CIRC
    end

    subgraph SystemSpec["System Spec -- L3-A.3"]
        IN["<b>Inputs</b><br/>dailySeed: string<br/>cellId: string"]
        OUT["<b>Outputs</b><br/>1-3 unidentified items<br/>in v3_items"]
        ALG["<b>Algorithm</b><br/>SHA-256 dailySeed + _ + cellId<br/>--> master hash<br/>Per slot: SHA-256 masterHash + _ + slotIndex<br/>--> species index mod 32,752<br/>Rarity weighting applied"]
        SF["<b>Skill Feed</b><br/>+1 to skill per item type<br/>on acquisition"]
        GT["<b>Gating</b><br/>Cell must be visited: A.2 complete"]
        DR["<b>Data Requirements</b><br/>species catalog<br/>v3_items<br/>daily_seed"]
        EV["<b>Events</b><br/>discovery.encounter<br/>discovery.item_acquired"]

        IN --> ALG
        ALG --> OUT
        SF --> GT
        GT --> DR
        DR --> EV
    end

    JTBD --> SystemSpec
