        EXECUTE["<b>EXECUTE</b><br/>Emit structured events to app_logs:<br/>category, event, data JSONB"]
        MONITOR["<b>MONITOR</b><br/>Query app_logs for<br/>debugging, alerts, analytics"]
        MODIFY["<b>MODIFY</b><br/>Add new events<br/>as features ship"]
        CONCLUDE["<b>CONCLUDE</b><br/>Full audit trail of all<br/>player and system actions"]
        SC["<b>Success Criteria</b><br/>Every state transition logged<br/>Structured queryable events<br/>No raw state mutations"]
        EM["<b>Emotions</b><br/>Confidence --> Visibility --> Control"]
        CIRC["<b>Circumstances</b><br/>All runtime state transitions<br/>Client and server side"]

        JP --> FJ
        ASP --> FJ
        FJ --> PLAN
        PLAN --> PREPARE --> EXECUTE --> MONITOR --> MODIFY --> CONCLUDE
        FJ --> RJ
        FJ --> SC
        FJ --> EM
        FJ --> CIRC
    end

    subgraph SystemSpec["System Spec -- L3-S.5"]
        EE["<b>Existing Events</b><br/>auth: sign_in_success/error,<br/>sign_up, sign_out,<br/>session_restored/expired<br/>items: fetch_success/error/empty<br/>app: cold_start, crash<br/>supabase: init_success/failure<br/>network: offline/online"]
