flowchart TD
    subgraph JTBD["JTBD: System - Make every discovered species identifiable"]
        direction TB

        JP["Job Performer: Enrichment Pipeline\n(automated system)"]
        ASP["Aspirations:\nSteadily grow the\nidentifiable species catalog"]
        FJ["Focus Job:\nMake every discovered\nspecies identifiable"]

        JP --> ASP --> FJ

        subgraph STEPS["Steps"]
            direction LR
            S1["PLAN\npg_cron fires\nevery 5 min"]
            S2["PREPARE\nQuery unenriched\nspecies"]
            S3["EXECUTE\n5-stage pipeline:\nclassify --> icon_prompt\n--> art_prompt --> icon --> art"]
            S4["MONITOR\nenrichver stamps\ntrack progress"]
            S5["MODIFY\nRetry on failure,\nskip permanently broken"]
            S6["CONCLUDE\nSpecies fully enriched,\n8 required columns populated"]
            S1 --> S2 --> S3 --> S4 --> S5 --> S6
        end

        FJ --> STEPS

        subgraph RJ["Related Jobs"]
            RJ1["Enable identification flow"]
            RJ2["Populate TCG card data"]
            RJ3["Generate species artwork"]
        end

        SC["Success Criteria:\nSpecies has all 8 required fields non-null:\nanimal_class, climate, brawn, wit, speed,\nsize, icon_url, art_url"]
        EM["Emotions: N/A (system job)"]
        CIR["Circumstances:\nUnenriched species exist in catalog,\npg_cron scheduler active"]

        STEPS --> SC
        STEPS --> EM
        STEPS --> CIR
        FJ --> RJ
    end

    subgraph SPEC["System Spec"]
        direction TB

        subgraph INPUTS["Inputs"]
            I1["Unenriched species row"]
        end

        subgraph OUTPUTS["Outputs"]
            O1["Fully enriched species:\nanimal_class, climate,\nbrawn, wit, speed, size,\nicon_url, art_url"]
        end

        TP["Throughput:\n~288 attempts/day\n(1 per 5-min tick)\nActual lower due to failures"]

        subgraph DATA["Data Requirements"]
            D1["species table"]
            D2["Supabase Storage (images)"]
            D3["enrichver columns"]
        end

        RES["Resolves Critiques:\n2.2 - enrichment gap (delta-sync to client)\n2.3 - fully enriched definition"]

        INPUTS --> OUTPUTS
        OUTPUTS --> TP
        TP --> DATA
        DATA --> RES
    end

    JTBD --> SPEC
