flowchart TD
    subgraph JTBD["JTBD Canvas -- L3-E.1: Trade Specimens"]
        JP["<b>Job Performer</b><br/>Player with duplicates<br/>or specific needs"]
        ASP["<b>Aspirations</b><br/>I have something you need<br/>Mutual benefit"]
        FJ["<b>Focus Job</b><br/>Trade specimens"]
        RJ["<b>Related Jobs</b><br/>E: Share my world with explorers<br/>C.2: Donate specimens"]
        PLAN["<b>PLAN</b><br/>Identify surplus specimens"]
        PREPARE["<b>PREPARE</b><br/>Find trade partner"]
        EXECUTE["<b>EXECUTE</b><br/>Propose trade,<br/>negotiate, confirm"]
        MONITOR["<b>MONITOR</b><br/>Items transfer"]
        MODIFY["<b>MODIFY</b><br/>Adjust offer if<br/>partner declines"]
        CONCLUDE["<b>CONCLUDE</b><br/>Both players enriched"]
        SC["<b>Success Criteria</b><br/>Fair exchange<br/>Both parties satisfied<br/>Items transfer atomically"]
        EM["<b>Emotions</b><br/>Hope --> Negotiation --> Mutual satisfaction"]
        CIRC["<b>Circumstances</b><br/>Player has surplus specimens<br/>or needs specific species for collections"]

        JP --> FJ
        ASP --> FJ
        FJ --> PLAN
        PLAN --> PREPARE --> EXECUTE --> MONITOR --> MODIFY --> CONCLUDE
        FJ --> RJ
        FJ --> SC
        FJ --> EM
        FJ --> CIRC
    end

    subgraph SystemSpec["System Spec -- L3-E.1"]
        IN["<b>Inputs</b><br/>Two players, items to exchange,<br/>trade proposal"]
        OUT["<b>Outputs</b><br/>Item ownership transferred,<br/>v3_items.status = traded,<br/>new items in recipient pack"]
        SF["<b>Skill Feed</b><br/>No skill impact from trading<br/>(skill XP from discovery/identification only)"]
        GT["<b>Gating</b><br/>Both players authenticated,<br/>items must be identified,<br/>mutual confirmation required"]
        DR["<b>Data Requirements</b><br/>v3_trade_proposals table,<br/>v3_trade_confirmations table,<br/>atomic item ownership transfer,<br/>ItemStatus.traded transition"]

        IN --> OUT
        SF --> GT
        GT --> DR
    end

    JTBD --> SystemSpec
