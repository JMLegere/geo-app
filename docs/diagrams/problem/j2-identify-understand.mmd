flowchart TD
    subgraph JTBD["JTBD: Identify and understand my collected specimens"]
        direction TB

        JP["Job Performer: Collector\n(wants to know what they found)"]
        ASP["Aspirations:\nTransform mystery into knowledge,\nfeel the dopamine of reveal"]
        FJ["Focus Job:\nIdentify and understand\nmy collected specimens"]

        JP --> ASP --> FJ

        subgraph STEPS["Steps"]
            direction LR
            S1["PLAN\nBrowse pack for\nunidentified items"]
            S2["PREPARE\nSelect item,\ncheck if enriched"]
            S3["EXECUTE\nHold card 1.2s,\nwatch charge animation"]
            S4["MONITOR\nSee stats roll,\nart reveal, affixes"]
            S5["MODIFY\nCompare with\nother specimens"]
            S6["CONCLUDE\nItem now identified\nwith full TCG card"]
            S1 --> S2 --> S3 --> S4 --> S5 --> S6
        end

        FJ --> STEPS

        subgraph RJ["Related Jobs"]
            RJ1["Explore to find more specimens"]
            RJ2["Donate to sanctuary collections"]
            RJ3["Compare stats across specimens"]
        end

        SC["Success Criteria:\n- Item identified\n- Stats visible (brawn/wit/speed)\n- Art revealed"]
        EM["Emotions:\nAnticipation --> Tension (charging) -->\nDopamine burst --> Pride"]
        CIR["Circumstances:\nHas unidentified item in pack,\nspecies is fully enriched"]

        STEPS --> SC
        STEPS --> EM
        STEPS --> CIR
        FJ --> RJ
    end

    subgraph SPEC["System Spec"]
        direction TB

        subgraph INPUTS["Inputs"]
            I1["Instance UUID"]
            I2["Species enrichment data\n(8 columns)"]
        end

        subgraph OUTPUTS["Outputs"]
            O1["Identified item with\nbrawn / wit / speed"]
            O2["Size and weight"]
            O3["Affixes"]
        end

        SF["Skill Feed:\n+1 to skill matching item type"]

        GT["Gating Requirements:\nSpecies must be FULLY ENRICHED\n(8-column NOT NULL predicate)"]

        subgraph DATA["Data Requirements"]
            D1["v3_items"]
            D2["species (enrichment columns)"]
            D3["SHA-256 stat roll"]
        end

        RES["Resolves Critiques:\n2.1 - stat model\n2.3 - fully enriched predicate\n2.4 - write queue"]

        INPUTS --> OUTPUTS
        OUTPUTS --> SF
        SF --> GT
        GT --> DATA
        DATA --> RES
    end

    JTBD --> SPEC
