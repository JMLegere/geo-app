flowchart TD
    subgraph JTBD["JTBD: System - Keep player data safe and consistent"]
        direction TB

        JP["Job Performer: Write Queue System\n(automated)"]
        ASP["Aspirations:\nNever lose player actions,\neventual consistency"]
        FJ["Focus Job:\nKeep player data\nsafe and consistent"]

        JP --> ASP --> FJ

        subgraph STEPS["Steps"]
            direction LR
            S1["PLAN\nPlayer action\ntriggers write"]
            S2["PREPARE\nOptimistic\nUI update"]
            S3["EXECUTE\nDispatch to\nSupabase"]
            S4["MONITOR\nAwait response,\ntrack status"]
            S5["MODIFY\nRetry with exponential\nbackoff on failure"]
            S6["CONCLUDE\nConfirmed or\nrolled back"]
            S1 --> S2 --> S3 --> S4 --> S5 --> S6
        end

        FJ --> STEPS

        subgraph RJ["Related Jobs"]
            RJ1["Persist identification results"]
            RJ2["Persist sanctuary donations"]
            RJ3["Persist cell visit records"]
        end

        SC["Success Criteria:\n- All writes eventually confirmed\n- No data loss\n- Idempotent operations"]
        EM["Emotions: N/A (system job)"]
        CIR["Circumstances:\nPlayer performs any mutating action,\nnetwork may be unreliable"]

        STEPS --> SC
        STEPS --> EM
        STEPS --> CIR
        FJ --> RJ
    end

    subgraph SPEC["System Spec"]
        direction TB

        subgraph INPUTS["Inputs"]
            I1["Player action:\nidentify, donate, visit"]
        end

        subgraph OUTPUTS["Outputs"]
            O1["Confirmed server state"]
            O2["Or rollback notification"]
        end

        RT["Retry Policy:\nExponential backoff,\nmax 3 retries"]

        ID["Idempotency:\nWHERE guards\n(e.g., WHERE identified=false)"]

        subgraph DATA["Data Requirements"]
            D1["v3_write_queue"]
            D2["v3_items"]
            D3["v3_cell_visits"]
            D4["v3_sanctuary_donations"]
        end

        RES["Resolves Critiques:\n2.4 - fire-and-forget unsafe"]

        INPUTS --> OUTPUTS
        OUTPUTS --> RT
        RT --> ID
        ID --> DATA
        DATA --> RES
    end

    JTBD --> SPEC
