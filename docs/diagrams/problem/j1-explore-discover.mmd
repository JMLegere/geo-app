flowchart TD
    subgraph JTBD["JTBD: Discover wildlife through real-world exploration"]
        direction TB

        JP["Job Performer: Explorer\n(casual outdoor player)"]
        ASP["Aspirations:\nFeel like a naturalist discovering\nreal species in real places"]
        FJ["Focus Job:\nDiscover wildlife through\nreal-world exploration"]

        JP --> ASP --> FJ

        subgraph STEPS["Steps"]
            direction LR
            S1["PLAN\nDecide where to walk"]
            S2["PREPARE\nOpen app, check GPS"]
            S3["EXECUTE\nWalk into new cell,\ntrigger encounter"]
            S4["MONITOR\nSee discovery modal,\ncheck what was found"]
            S5["MODIFY\nAdjust route for\nunexplored cells"]
            S6["CONCLUDE\nItems in pack,\ncells revealed on map"]
            S1 --> S2 --> S3 --> S4 --> S5 --> S6
        end

        FJ --> STEPS

        subgraph RJ["Related Jobs"]
            RJ1["Identify collected specimens"]
            RJ2["Build sanctuary collection"]
            RJ3["Track exploration progress"]
        end

        SC["Success Criteria:\n- New species discovered\n- Fog cleared\n- Visit recorded"]
        EM["Emotions:\nCuriosity --> Surprise --> Satisfaction"]
        CIR["Circumstances:\nOutdoors, GPS-enabled device,\nwalking in explorable area"]

        STEPS --> SC
        STEPS --> EM
        STEPS --> CIR
        FJ --> RJ
    end

    subgraph SPEC["System Spec"]
        direction TB

        subgraph INPUTS["Inputs"]
            I1["GPS coordinates"]
            I2["Daily seed"]
            I3["Cell ID"]
        end

        subgraph OUTPUTS["Outputs"]
            O1["Unidentified items\n(1-3 per cell)"]
            O2["Cell visit record"]
            O3["Fog update"]
        end

        SF["Skill Feed:\n+1 to skill matching item type\n(Zoology for fauna, Botany for flora,\nGeology for minerals, etc.)"]

        GT["Gating Requirements:\nNone - exploration is always available"]

        subgraph DATA["Data Requirements"]
            D1["v3_cell_visits"]
            D2["v3_items"]
            D3["species catalog"]
            D4["daily_seed"]
        end

        INPUTS --> OUTPUTS
        OUTPUTS --> SF
        SF --> GT
        GT --> DATA
    end

    JTBD --> SPEC
