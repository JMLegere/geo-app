# EarthNova beta/prod environment variables
# Copy to .env for local development. Never commit .env.

# Flutter web reads these at build time via --dart-define.
# Set them per environment in Railway and in any local build shell.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-public-anon-key

# Supabase management token for CLI / GitHub Actions.
# Generate at: https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=your-access-token-here

# Railway deploy token for GitHub Actions.
RAILWAY_TOKEN=your-railway-token-here

# Optional explicit refs used by CI/CD workflows.
SUPABASE_BETA_PROJECT_REF=ggkvcpgvxqaqzwxehlns
SUPABASE_PRODUCTION_PROJECT_REF=bfaczcsrpfcbijoaeckb
SUPABASE_BETA_DB_PASSWORD=your-beta-db-password
SUPABASE_PRODUCTION_DB_PASSWORD=your-production-db-password
RAILWAY_PROJECT_ID=e693a14e-316c-4280-842a-6258a048d326

# Build metadata (local defaults only; CI/Railway injects real values)
BUILD_TIMESTAMP=local
APP_VERSION=dev
RAILWAY_GIT_COMMIT_SHA=
