# EarthNova v3 — Environment Variables
# Copy to .env for local development. Never commit .env.
# Most variables are baked into Dockerfile for Railway (prod).
# The only secret that must NOT be committed is SUPABASE_ACCESS_TOKEN.

# ── Supabase (Flutter dart-define) ───────────────────────────────────────────

# Public Supabase project URL — safe to commit (already in Dockerfile)
SUPABASE_URL=https://bfaczcsrpfcbijoaeckb.supabase.co

# Public anon key — safe to commit (already in Dockerfile)
# RLS policies enforce per-user access for all v3_ tables.
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImJmYWN6Y3NycGZjYmlqb2FlY2tiIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzI1NzE3ODYsImV4cCI6MjA4ODE0Nzc4Nn0.hyjp1NRiteavWfBnch1LpRARtiN5lvpP0PztbRwqPJ8

# ── Supabase CLI ──────────────────────────────────────────────────────────────

# Supabase CLI + API access token — NEVER COMMIT
# Generate at: https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=your-access-token-here

# ── Build (injected by Railway CI) ───────────────────────────────────────────

# Build timestamp shown in app — leave as 'local' for dev
BUILD_TIMESTAMP=local

# App version string included in app_logs events
APP_VERSION=dev

# Git commit SHA — injected by Railway, used for log tagging and cache-busting
RAILWAY_GIT_COMMIT_SHA=
