{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://earthnova.local/schemas/cell_geometry_artifact.schema.json",
  "title": "EarthNova Cell Geometry Artifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "source",
    "source_version",
    "coverage",
    "cells"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "cell-geometry-artifact/v1"
    },
    "source": {
      "type": "string",
      "minLength": 1,
      "description": "Generator/import source identifier, for example earthnova-voronoi-generator."
    },
    "source_version": {
      "type": "string",
      "minLength": 1,
      "description": "Immutable generation/import batch id. Maps to cell_geometry_versions.source_version."
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "generator": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "name": { "type": "string" },
        "version": { "type": "string" },
        "commit": { "type": "string" },
        "parameters": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "coverage": {
      "$ref": "#/$defs/coverage"
    },
    "cells": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/cell" }
    }
  },
  "$defs": {
    "coverage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["geometry"],
      "properties": {
        "geometry": { "$ref": "#/$defs/multiPolygonGeometry" },
        "properties": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "description": "Authoritative generation boundary. Validation compares union(cells) against this geometry. Coordinates are GeoJSON-standard [lng, lat]."
    },
    "cell": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cell_id", "geometry"],
      "properties": {
        "cell_id": {
          "type": "string",
          "minLength": 1,
          "description": "Must match cell_properties.cell_id exactly."
        },
        "geometry": {
          "oneOf": [
            { "$ref": "#/$defs/polygonGeometry" },
            { "$ref": "#/$defs/multiPolygonGeometry" }
          ],
          "description": "Cell polygon geometry. Importer normalizes Polygon to MultiPolygon in PostGIS. Coordinates are GeoJSON-standard [lng, lat]."
        },
        "properties": {
          "type": "object",
          "additionalProperties": true,
          "description": "Optional source metadata preserved into staging raw_properties and canonical metadata."
        }
      }
    },
    "position": {
      "type": "array",
      "prefixItems": [
        {
          "type": "number",
          "minimum": -180,
          "maximum": 180,
          "description": "Longitude"
        },
        {
          "type": "number",
          "minimum": -90,
          "maximum": 90,
          "description": "Latitude"
        }
      ],
      "items": false,
      "minItems": 2,
      "maxItems": 2
    },
    "linearRing": {
      "type": "array",
      "minItems": 4,
      "items": { "$ref": "#/$defs/position" },
      "description": "Closed GeoJSON linear ring. JSON Schema cannot enforce first point equals last; importer/validator must enforce closure."
    },
    "polygonCoordinates": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/linearRing" },
      "description": "GeoJSON Polygon coordinates: rings -> positions. First ring is exterior; later rings are holes."
    },
    "multiPolygonCoordinates": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/polygonCoordinates" },
      "description": "GeoJSON MultiPolygon coordinates: polygons -> rings -> positions."
    },
    "polygonGeometry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "coordinates"],
      "properties": {
        "type": { "const": "Polygon" },
        "coordinates": { "$ref": "#/$defs/polygonCoordinates" }
      }
    },
    "multiPolygonGeometry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "coordinates"],
      "properties": {
        "type": { "const": "MultiPolygon" },
        "coordinates": { "$ref": "#/$defs/multiPolygonCoordinates" }
      }
    }
  }
}
